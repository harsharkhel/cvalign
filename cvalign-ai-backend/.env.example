DATABASE_URL=sqlite:///./cvalign_ai.db

# JWT (JWT_SECRET is an alias — use JWT_SECRET_KEY)
JWT_SECRET_KEY=change_this_secret_key
JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_EXPIRES_IN=1440

# Firebase Google sign-in (verify Firebase ID tokens from frontend)
FIREBASE_PROJECT_ID=your_firebase_project_id
GOOGLE_APPLICATION_CREDENTIALS=

# Google OAuth 2.0 (backend redirect flow + credential token verification)
GOOGLE_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:8000/auth/google/callback

# Login notification email (Gmail SMTP or SendGrid SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_USE_TLS=true

# Google Sheets audit log (service account — never store passwords here)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=your_google_sheet_id

# AI analysis (never expose keys to frontend)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
GEMINI_API_KEY=

# Job APIs
ADZUNA_APP_ID=your_adzuna_app_id_here
ADZUNA_APP_KEY=your_adzuna_app_key_here
ADZUNA_COUNTRY=gb
JOOBLE_API_KEY=your_jooble_api_key_here
SERPAPI_KEY=
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

UPLOAD_DIR=app/uploads
MAX_UPLOAD_SIZE_MB=5

ADMIN_EMAIL=
ADMIN_PASSWORD=

ENV=development
INTERNSHALA_SOURCE_ENABLED=false
JOB_LIVE_SEARCH_ENABLED=true
